# infra/vault — non-sensitive defaults. Copy to terraform.tfvars and fill in.
# Sensitive variable (postgres_password) must be set via environment variable:
#
#   export TF_VAR_postgres_password="..."   # must match infra/aws TF_VAR_postgres_password
#
# Vault authentication via environment variable:
#   export VAULT_TOKEN="..."                # HCP Vault admin token

# HCP Vault Dedicated cluster address (include port if not 443)
vault_addr = "https://<cluster-id>.hashicorp.cloud:8200"

# Child namespace Terraform will create under admin — change to reuse this config for different demos
vault_namespace = "cicd-demo-ns"

# Outputs from infra/azure/ — run `terraform output` there first
azure_tenant_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
azure_client_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Private IP of the demo VM — Vault connects over the HVN peering, NOT the public hostname.
# Get it after applying infra/aws/:
#   cd infra/aws && terraform output -raw demo_vm_private_ip
db_hostname = "10.0.1.x"

# Defaults — only override if changed
postgres_username = "postgres"
db_port           = 5432
db_name           = "demo_app"
